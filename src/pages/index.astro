---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import "../styles/pages/home.css";

const posts = await getCollection("blog");
posts.sort((a, b) => (a.data.date < b.data.date ? 1 : -1));
const recentPosts = posts.slice(0, 2);

const thinks = await getCollection("think");
thinks.sort((a, b) => (a.data.date < b.data.date ? 1 : -1));
const recentThinks = thinks.slice(0, 2);

const musics = await getCollection("music");
musics.sort((a, b) => (a.data.date < b.data.date ? 1 : -1));
const recentMusics = musics.slice(0, 2);
---

<BaseLayout>
  <section class="home-intro">
    <p>민영, 코드 쓰고 음악 듣고 생각 적는 사람.</p>
    <p>개발하고 음악 듣는 일상을 기록합니다.</p>
  </section>

  {recentPosts.length > 0 && (
    <section class="home-section">
      <h2 class="home-section-title"><a href="/posts">글</a></h2>
      <ul class="home-list">
        {recentPosts.map((post) => (
          <li class="home-list-item">
            <a href={`/posts/${post.slug}`}>{post.data.title}</a>
            <span class="home-date">{post.data.date}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  {recentThinks.length > 0 && (
    <section class="home-section">
      <h2 class="home-section-title"><a href="/think">생각</a></h2>
      <ul class="home-list">
        {recentThinks.map((item) => (
          <li class="home-list-item">
            <a href={`/think`}>{item.data.title || item.data.date}</a>
            <span class="home-date">{item.data.date}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  {recentMusics.length > 0 && (
    <section class="home-section">
      <h2 class="home-section-title"><a href="/musics">음악</a></h2>
      <ul class="home-list">
        {recentMusics.map((item) => (
          <li class="home-list-item">
            <a href="/musics">{item.data.artist && `${item.data.artist} - `}{item.data.title}</a>
            <span class="home-date">{item.data.date}</span>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>
