---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import "../styles/pages/home.css";

const posts = await getCollection("blog");
posts.sort((a, b) => (a.data.date < b.data.date ? 1 : -1));
const recentPosts = posts.slice(0, 5);

const musics = await getCollection("music");
musics.sort((a, b) => (a.data.date < b.data.date ? 1 : -1));
const recentMusics = musics.slice(0, 5);
---

<BaseLayout>
  <section class="home-intro">
    <h1>민영, 코드 쓰고 음악 듣고 생각 적는 사람.</h1>
    <p>개발하고 음악 듣는 일상을 기록합니다.</p>
  </section>

  {recentPosts.length > 0 && (
    <section class="home-section">
      <h2 class="home-section-title">최근 글</h2>
      <ul class="home-list">
        {recentPosts.map((post) => (
          <li>
            <a href={`/posts/${post.slug}`}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {recentMusics.length > 0 && (
    <section class="home-section">
      <h2 class="home-section-title">최근 음악</h2>
      <ul class="home-list">
        {recentMusics.map((item) => (
          <li>
            <a href="/musics">{item.data.artist && `${item.data.artist} - `}{item.data.title}</a>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>
